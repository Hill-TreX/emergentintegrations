{
  "name": "emergentintegrations",
  "version": "2.5.0",
  "description": "A Node.js library for various integrations including payments and LLM services - exact port of the Python emergentintegrations package.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "node dist/test.js"
  },
  "keywords": [
    "llm",
    "openai",
    "gemini",
    "anthropic",
    "stripe",
    "payments",
    "emergent",
    "integrations",
    "video-generation",
    "image-generation",
    "speech-to-text",
    "text-to-speech",
    "realtime"
  ],
  "author": "Hill TreX",
  "license": "MIT",
  "dependencies": {
    "openai": "^4.50.0",
    "@google/genai": "^1.0.0",
    "stripe": "^14.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "README.md",
    "AGENTS.md",
    ".cursorrules"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./llm": {
      "require": "./dist/llm/index.js",
      "types": "./dist/llm/index.d.ts"
    },
    "./llm/chat": {
      "require": "./dist/llm/chat.js",
      "types": "./dist/llm/chat.d.ts"
    },
    "./llm/openai": {
      "require": "./dist/llm/openai/index.js",
      "types": "./dist/llm/openai/index.d.ts"
    },
    "./llm/gemini": {
      "require": "./dist/llm/gemini/index.js",
      "types": "./dist/llm/gemini/index.d.ts"
    },
    "./payments/stripe": {
      "require": "./dist/payments/stripe/index.js",
      "types": "./dist/payments/stripe/index.d.ts"
    }
  },
  "bin": {
    "emergentintegrations": "./bin/init.js"
  }
}