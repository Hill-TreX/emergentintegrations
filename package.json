{
  "name": "emergentintegrations",
  "version": "1.2.0",
  "description": "Lightweight async LLM chat client built on the OpenAI SDK, with optional Emergent proxy routing.",
  "main": "src/index.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./llm": {
      "import": "./src/llm/index.js"
    },
    "./llm/chat": {
      "import": "./src/llm/chat.js"
    },
    "./llm/openai": {
      "import": "./src/llm/openai/index.js"
    }
  },
  "scripts": {
    "build": "node scripts/build-cjs.js",
    "test": "node tests/test.js"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "google",
    "ai",
    "emergent"
  ],
  "license": "MIT",
  "dependencies": {
    "openai": "^4.100.0"
  }
}