{
  "name": "emergentintegrations",
  "version": "3.0.1",
  "description": "A Node.js library for various integrations including payments and LLM services - exact port of the Python emergentintegrations package.",
  "main": "dist/cjs/index.js",
  "types": "dist/cjs/index.d.ts",
  "scripts": {
    "build": "node scripts/build.js",
    "prepare": "npm run build",
    "test": "node dist/cjs/test.js"
  },
  "keywords": [
    "llm",
    "openai",
    "gemini",
    "anthropic",
    "stripe",
    "payments",
    "emergent",
    "integrations",
    "video-generation",
    "image-generation",
    "speech-to-text",
    "text-to-speech",
    "realtime"
  ],
  "author": "Hill TreX",
  "license": "MIT",
  "dependencies": {
    "openai": "^6.0.0",
    "@google/genai": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "src",
    "bin",
    "docs",
    "README.md",
    "AGENTS.md",
    "CLAUDE.md",
    ".cursorrules"
  ],
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./llm": {
      "types": "./dist/cjs/llm/index.d.ts",
      "import": "./dist/esm/llm/index.js",
      "require": "./dist/cjs/llm/index.js"
    },
    "./llm/chat": {
      "types": "./dist/cjs/llm/chat.d.ts",
      "import": "./dist/esm/llm/chat.js",
      "require": "./dist/cjs/llm/chat.js"
    },
    "./llm/utils": {
      "types": "./dist/cjs/llm/utils.d.ts",
      "import": "./dist/esm/llm/utils.js",
      "require": "./dist/cjs/llm/utils.js"
    },
    "./llm/models": {
      "types": "./dist/cjs/llm/models.d.ts",
      "import": "./dist/esm/llm/models.js",
      "require": "./dist/cjs/llm/models.js"
    },
    "./llm/client": {
      "types": "./dist/cjs/llm/client.d.ts",
      "import": "./dist/esm/llm/client.js",
      "require": "./dist/cjs/llm/client.js"
    },
    "./llm/openai": {
      "types": "./dist/cjs/llm/openai/index.d.ts",
      "import": "./dist/esm/llm/openai/index.js",
      "require": "./dist/cjs/llm/openai/index.js"
    },
    "./llm/openai/realtime": {
      "types": "./dist/cjs/llm/openai/realtime.d.ts",
      "import": "./dist/esm/llm/openai/realtime.js",
      "require": "./dist/cjs/llm/openai/realtime.js"
    },
    "./llm/openai/textToSpeech": {
      "types": "./dist/cjs/llm/openai/textToSpeech.d.ts",
      "import": "./dist/esm/llm/openai/textToSpeech.js",
      "require": "./dist/cjs/llm/openai/textToSpeech.js"
    },
    "./llm/openai/speechToText": {
      "types": "./dist/cjs/llm/openai/speechToText.d.ts",
      "import": "./dist/esm/llm/openai/speechToText.js",
      "require": "./dist/cjs/llm/openai/speechToText.js"
    },
    "./llm/openai/imageGeneration": {
      "types": "./dist/cjs/llm/openai/imageGeneration.d.ts",
      "import": "./dist/esm/llm/openai/imageGeneration.js",
      "require": "./dist/cjs/llm/openai/imageGeneration.js"
    },
    "./llm/openai/videoGeneration": {
      "types": "./dist/cjs/llm/openai/videoGeneration.d.ts",
      "import": "./dist/esm/llm/openai/videoGeneration.js",
      "require": "./dist/cjs/llm/openai/videoGeneration.js"
    },
    "./llm/gemini": {
      "types": "./dist/cjs/llm/gemini/index.d.ts",
      "import": "./dist/esm/llm/gemini/index.js",
      "require": "./dist/cjs/llm/gemini/index.js"
    },
    "./llm/gemini/imageGeneration": {
      "types": "./dist/cjs/llm/gemini/imageGeneration.d.ts",
      "import": "./dist/esm/llm/gemini/imageGeneration.js",
      "require": "./dist/cjs/llm/gemini/imageGeneration.js"
    },
    "./llm/gemini/videoGeneration": {
      "types": "./dist/cjs/llm/gemini/videoGeneration.d.ts",
      "import": "./dist/esm/llm/gemini/videoGeneration.js",
      "require": "./dist/cjs/llm/gemini/videoGeneration.js"
    },
    "./payments": {
      "types": "./dist/cjs/payments/index.d.ts",
      "import": "./dist/esm/payments/index.js",
      "require": "./dist/cjs/payments/index.js"
    },
    "./payments/stripe": {
      "types": "./dist/cjs/payments/stripe/index.d.ts",
      "import": "./dist/esm/payments/stripe/index.js",
      "require": "./dist/cjs/payments/stripe/index.js"
    },
    "./payments/stripe/checkout": {
      "types": "./dist/cjs/payments/stripe/checkout.d.ts",
      "import": "./dist/esm/payments/stripe/checkout.js",
      "require": "./dist/cjs/payments/stripe/checkout.js"
    }
  },
  "bin": {
    "emergentintegrations": "./bin/init.js"
  },
  "peerDependencies": {
    "stripe": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "stripe": {
      "optional": true
    }
  },
  "module": "dist/esm/index.js"
}